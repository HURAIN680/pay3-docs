  "keyFeatures": [
    "Programmable AI Wallets — Stellar-based wallets with delegated permissions for AI agents, no private key exposure",
    "Session Keys — Ephemeral Soroban session keypairs with time-bound, budget-limited spending permissions",
    "Policy Engine — Three-tier execution model (Auto / Pending Approval / Reject) with daily/monthly budgets and per-tx limits",
    "MCP Server — Model Context Protocol server exposing get_balance, transfer, and get_transaction_history tools to any MCP-compatible AI assistant",
    "x402 Payments — HTTP 402-based stateless micropayments for machine-to-machine API access",
    "Soroban Smart Account — On-chain USDC vault contract enforcing session limits independently of off-chain policy",
    "Manual Approval Workflow — Human-in-the-loop approval for transactions exceeding configurable thresholds",
    "DeFi Integrations — Blend lending/borrowing, Phoenix swaps, Aquarius liquidity management via AI",
    "Contacts & Recipient Resolution — Named address book for AI-safe recipient lookup by alias or display name",
    "Audit Logs & Analytics — Full transaction lifecycle tracking, budget usage, and cost attribution"
  ],
